{
  "name": "tabulakit",
  "displayName": "TabulaKit",
  "description": "Documentation site builder companion — live preview, guided setup, and action controls for TabulaKit projects",
  "version": "0.1.0",
  "publisher": "heatherstoneio",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heatherstoneio/tabulakit-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:.tabulakit/**"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tabulakit.showDashboard",
        "title": "TabulaKit: Show Dashboard"
      },
      {
        "command": "tabulakit.refreshPreview",
        "title": "TabulaKit: Refresh Preview"
      },
      {
        "command": "tabulakit.resetLayout",
        "title": "TabulaKit: Reset Layout"
      },
      {
        "command": "tabulakit.checkForUpdates",
        "title": "TabulaKit: Check for Updates"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tabulakit",
          "title": "TabulaKit",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "tabulakit": [
        {
          "id": "tabulakit.welcome",
          "name": "TabulaKit",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "npm run compile && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}
